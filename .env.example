# Set these in the Netlify dashboard under Site → Environment variables
# (or in a local .env file for running with `netlify dev`)

# Used by Netlify Functions (server-side, never exposed to browser)
CLIENT_ID=YOUR_CLIENT_ID
CLIENT_SECRET=YOUR_CLIENT_SECRET
REDIRECT_URI=https://YOUR-SITE.netlify.app/callback

# Used by the React build (must be prefixed REACT_APP_)
REACT_APP_CLIENT_ID=YOUR_CLIENT_ID
REACT_APP_REDIRECT_URI=https://YOUR-SITE.netlify.app/callback

# Local development only (run `npm run server` alongside `npm start`)
# PORT=4000
